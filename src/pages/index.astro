---
import InventoryCaroussel from '../components/InventoryCaroussel.svelte';
import Contact from '../components/Contact.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import Layout from '../layouts/Layout.astro';
import type { vehicule } from '../type';

const apiBaseUrl = import.meta.env.API_URL;
let vehicules: vehicule[] = [];

try {
  const res = await fetch(`${apiBaseUrl}/api/vehicules`);
  if (res.ok) vehicules = await res.json();
} catch (e) {
  console.error("Failed to fetch vehicles", e);
}

const title = "Junction Retro | Boutique of Collector Vehicles";
const description = "Discover a unique collection of classic and exceptional cars. From vintage Porsches to collector Ferraris, find your rare gem at Junction Retro.";
---

<Layout title={title} description={description}>
  <main>
    <WelcomeSection />
    
    <section class="bg-white py-20 border-y border-slate-100">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-xs uppercase tracking-[0.4em] text-slate-400 font-bold mb-6">Our Philosophy</h2>
        <p class="text-2xl md:text-3xl font-serif text-slate-800 leading-relaxed italic">
          "We don't just sell automobiles; we pass on fragments of history and masterpieces of engineering that have defied time."
        </p>
      </div>
    </section>

    <div id="inventory">
      <InventoryCaroussel vehicules={vehicules} client:load />
    </div>

    <section class="bg-[#F5F5F0] py-24 px-6 border-t border-slate-200">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-center">
          <div>
            <h3 class="font-serif text-xl mb-4">Certified Expertise</h3>
            <p class="text-slate-600 font-light leading-relaxed">Each vehicle in our collection undergoes a rigorous 150-point inspection by our master mechanics.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl mb-4">Heritage & Provenance</h3>
            <p class="text-slate-600 font-light leading-relaxed">We trace the complete history of each automobile to guarantee its authenticity and investment value.</p>
          </div>
        </div>
      </div>
    </section>

    <Contact />
  </main>
</Layout>

<style>
  /* Styles locaux si nécessaire */
</style>