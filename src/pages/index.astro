---
const apiBaseUrl = import.meta.env.API_URL;

let vehicules = [];
try {
    const response = await fetch(`${apiBaseUrl}/api/vehicules`);
    if (response.ok) {
        vehicules = await response.json();
    }
} catch (error) {
    console.error("Erreur de fetch :", error);
}

import Layout from '../layouts/Layout.astro';
import type { vehicule } from '../type';
---

<Layout title="Catalogue Centra">
  <main>
    <h1>Nos Véhicules</h1>
    
    {vehicules.length === 0 && <p>Aucun véhicule trouvé ou erreur API.</p>}

    <div class="grid">
      {vehicules.map((v: vehicule) => (
        <div class="card">
          {v.images && v.images.length > 0 && (
            <img src={v.images[0]} alt={v.model} />
          )}
          <h2>{v.model}</h2>
          <p>{v.price} €</p>
          <a href={`/vehicule/${v.id}`}>Détails</a>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .card { border: 1px solid #ccc; padding: 1rem; border-radius: 8px; }
  img { max-width: 100%; height: auto; border-radius: 4px; }
</style>
