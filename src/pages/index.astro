---
import InventoryCaroussel from '../components/InventoryCaroussel.svelte';
import Contact from '../components/Contact.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import Layout from '../layouts/Layout.astro';
import type { vehicule } from '../type';

const apiBaseUrl = import.meta.env.API_URL;
let vehicules: vehicule[] = [];

try {
  const res = await fetch(`${apiBaseUrl}/api/vehicules`);
  if (res.ok) vehicules = await res.json();
} catch (e) {
  console.error("Failed to fetch vehicles", e);
}

const title = "Junction Retro | Boutique de Véhicules de Collection";
const description = "Découvrez une collection unique de voitures classiques et d'exception. De la Porsche vintage à la Ferrari de collection, trouvez la perle rare chez Junction Retro.";
---

<Layout title={title} description={description}>
  <main>
    <WelcomeSection />
    
    <section class="bg-white py-20 border-y border-slate-100">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-xs uppercase tracking-[0.4em] text-slate-400 font-bold mb-6">Notre Philosophie</h2>
        <p class="text-2xl md:text-3xl font-serif text-slate-800 leading-relaxed italic">
          "Nous ne vendons pas simplement des automobiles, nous transmettons des fragments d'histoire et des chefs-d'œuvre d'ingénierie qui ont défié le temps."
        </p>
      </div>
    </section>

    <div id="inventory">
      <InventoryCaroussel vehicules={vehicules} client:load />
    </div>

    <section class="bg-[#F5F5F0] py-24 px-6 border-t border-slate-200">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div>
            <h3 class="font-serif text-xl mb-4">Expertise Certifiée</h3>
            <p class="text-slate-600 font-light leading-relaxed">Chaque véhicule de notre collection subit une inspection rigoureuse de 150 points par nos maîtres mécaniciens.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl mb-4">Héritage & Provenance</h3>
            <p class="text-slate-600 font-light leading-relaxed">Nous traçons l'historique complet de chaque automobile pour garantir son authenticité et sa valeur d'investissement.</p>
          </div>
        </div>
      </div>
    </section>

    <Contact />
  </main>
</Layout>

<style>
  /* Styles locaux si nécessaire */
</style>